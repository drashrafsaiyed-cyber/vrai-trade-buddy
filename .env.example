# ============================================
# VRAI TRADE BUDDY — Environment Variables
# ============================================
# Copy this file to .env and fill in values
# NEVER commit .env to GitHub

# --- AI Brain ---
NVIDIA_API_KEY=your_nvidia_nim_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# --- Telegram (add tomorrow after ban lifted) ---
TELEGRAM_BOT_TOKEN=ADD_TOMORROW
TELEGRAM_CHAT_ID=ADD_TOMORROW

# --- Groww (for market data) ---
# GrowwMCP is used via HTTP — no key needed if using Claude integration
# For standalone buddy, we use public NSE data + Groww web scraping

# --- Google Sheets (trade log) ---
GOOGLE_SHEETS_CREDS_FILE=credentials.json
TRADE_LOG_SHEET_ID=your_google_sheet_id_here

# --- App Settings ---
APP_ENV=development
PORT=8000
